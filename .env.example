# === Required ===
# Neon PostgreSQL connection string (from Vercel integration)
DATABASE_URL="postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Vercel Blob read/write token (from Vercel Blob store)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Resend API key (https://resend.com)
RESEND_API_KEY="re_xxx"
# A verified sender address (e.g., hello@shoaibramani.com or Resend's onboarding sandbox)
RESEND_FROM="Shoaib Ramani <hello@shoaibramani.com>"

# Admin email — OTPs + contact form notifications are sent here
ADMIN_EMAIL="shoaibramani1@gmail.com"

# 32-char random string — used to sign session JWTs
NEXTAUTH_SECRET="change-me-to-a-long-random-string-please-32chars"

# Public site URL (used for OG, canonicals, share links)
NEXT_PUBLIC_SITE_URL="https://shoaibramani.com"

# === First-run admin bootstrap ===
# On first DB migration + seed, these create the admin account.
# Change the password AFTER first login.
SEED_ADMIN_EMAIL="shoaibramani1@gmail.com"
SEED_ADMIN_PASSWORD="ChangeMe#2026!"
